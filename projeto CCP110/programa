def carregar_usuarios ():

    usuarios = []

    senhas = []

    try:

        with open ("usuarios.txt", "r") as arquivo:

            for i in arquivo:
                i = i.strip()

                if "-" in i:

                    partes = i.split("-")

                    usuario_limpo = partes[0].split(":")
                    senha_limpo = partes[1].split(":")

                    usuario_final = usuario_limpo[1].strip()
                    senha_final = senha_limpo[1].strip()

                    usuarios.append(usuario_final)

                    senhas.append(senha_final)

    except FileNotFoundError:
        pass
    return usuarios, senhas

def salvar_usuarios(usuarios, senhas):
    with open ("usuarios.txt", "w") as arquivo:

        for i in range (len(usuarios)):

            arquivo.write(" usuario: %s - senha: %s \n" %(usuarios[i], senhas[i]))

def salvar_videos(videos):

    with open("videos.txt", "w") as arquivo:

        for i in range (len(videos)):
            arquivo.write("nome do video: %s\n" %videos[i])

def carregar_videos():
    
    videos = []
    try:

        with open ("videos.txt", "r") as arquivo:

            for i in arquivo:
                partes = i.split(":")
                if ":" in i:
                    partes = i.split(":")
                    videos.append(partes[1].strip())

    except FileNotFoundError:
        pass

    return videos

